{
    "name": "ninerouter-mcp",
    "version": "1.0.0",
    "type": "module",
    "description": "MCP server for 9Router with model discovery, automatic fallback, and type-safe validation",
    "files": [
        "dist",
        "README.md"
    ],
    "bin": {
        "ninerouter-mcp": "./dist/index.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "prepack": "npm run build",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "create-config": "tsx src/create-config.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/server": "^2.0.0-beta.2",
        "@iarna/toml": "^2.2.5",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0"
    }
}