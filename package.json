{
    "name": "ninerouter-mcp",
    "version": "1.1.0",
    "type": "module",
    "description": "MCP server for 9Router with model discovery, automatic fallback, and type-safe validation",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=20"
    },
    "author": "Farhan Brillan Widyakirana <https://tojoo.dev>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/k1rana/ninerouter-mcp.git"
    },
    "keywords": [
        "9router",
        "mcp",
        "model-context-protocol",
        "ai",
        "llm",
        "tools",
        "web-search",
        "embeddings",
        "tts",
        "stt",
        "image-generation"
    ],
    "homepage": "https://github.com/k1rana/ninerouter-mcp#readme",
    "bugs": {
        "url": "https://github.com/k1rana/ninerouter-mcp/issues"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "bin": {
        "ninerouter-mcp": "dist/index.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "prepack": "npm run build",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "create-config": "tsx src/create-config.ts",
        "release": "semantic-release",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "check": "npm run typecheck && npm run lint && npm run format:check",
        "prepare": "husky"
    },
    "dependencies": {
        "@modelcontextprotocol/server": "^2.0.0-beta.4",
        "toml": "^5.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/npm": "^13.1.5",
        "@types/node": "^22.20.0",
        "eslint": "^10.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.0.0",
        "prettier": "^3.9.5",
        "semantic-release": "^25.0.7",
        "tsx": "^4.23.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.64.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,cjs,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}
